STOCK_API_PROVIDER=real
STOCK_API_TIMEOUT_SECONDS=12
STOCK_API_CACHE_TTL_SECONDS=60

ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

OPENDART_API_KEY=your_opendart_key
OPENDART_BASE_URL=https://opendart.fss.or.kr/api

RESEARCH_LLM_PROVIDER=auto
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-5-mini

STOCK_RADAR_SYMBOLS=NVDA,AMD,AVGO,MSFT,CRWD
STOCK_RADAR_SECTORS=NVDA:반도체,AMD:반도체,AVGO:반도체,MSFT:소프트웨어,CRWD:사이버보안
STOCK_OVERVIEW_BENCHMARKS=SPY:S&P 500,QQQ:NASDAQ 100,SMH:반도체,IWM:러셀 2000
STOCK_SECTOR_PROXIES=XLK:기술주,XLF:금융,XLE:에너지
