{
  "name": "stock-workspace",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "test:e2e": "playwright test",
    "dev:api": "node scripts/run-python.mjs -m uvicorn app.main:app --reload --app-dir apps/api",
    "check:contracts": "node scripts/run-python.mjs scripts/check_contract_parity.py",
    "smoke:api": "node scripts/run-python.mjs scripts/api_smoke.py",
    "guard:no-secrets": "node scripts/run-python.mjs scripts/no_secrets_guard.py",
    "verify:minimal": "node scripts/run-python.mjs scripts/verify_minimal.py",
    "verify:web": "node scripts/run-python.mjs scripts/verify_workspace.py --group web",
    "verify:api": "node scripts/run-python.mjs scripts/verify_workspace.py --group api",
    "verify:standard": "node scripts/run-python.mjs scripts/verify_workspace.py --group standard",
    "verify:standard:json": "node scripts/run-python.mjs scripts/verify_workspace.py --group standard --json",
    "verify:release": "node scripts/run-python.mjs scripts/verify_workspace.py --group release",
    "verify:release:json": "node scripts/run-python.mjs scripts/verify_workspace.py --group release --json"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.14",
      "ip-address": "10.2.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
