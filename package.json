{
  "name": "stock-workspace",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api",
    "check:contracts": "python scripts/check_contract_parity.py",
    "smoke:api": "python scripts/api_smoke.py",
    "smoke:discord-bridge": "python scripts/test_discord_bridge.py",
    "guard:no-secrets": "python scripts/no_secrets_guard.py",
    "ralph:init": "powershell -ExecutionPolicy Bypass -File scripts/ralph-init.ps1",
    "verify:ralph": "python scripts/verify_ralph_setup.py",
    "verify:automation": "python scripts/verify_workspace.py --group automation",
    "verify:minimal": "python scripts/verify_minimal.py",
    "verify:web": "python scripts/verify_workspace.py --group web",
    "verify:api": "python scripts/verify_workspace.py --group api",
    "verify:standard": "python scripts/verify_workspace.py --group standard",
    "verify:standard:json": "python scripts/verify_workspace.py --group standard --json",
    "verify:release": "python scripts/verify_workspace.py --group release",
    "verify:release:json": "python scripts/verify_workspace.py --group release --json"
  }
}
