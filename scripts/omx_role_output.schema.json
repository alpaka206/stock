{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OMX Role Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "role",
    "status",
    "summary",
    "rationale",
    "proposed_action",
    "team_message",
    "question_for_next",
    "reply_to",
    "risks",
    "verification",
    "changed_files",
    "followups",
    "confidence",
    "needs_human"
  ],
  "properties": {
    "role": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "continue",
        "done",
        "blocked",
        "idle",
        "pass",
        "fail"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "proposed_action": {
      "type": "string",
      "minLength": 1
    },
    "team_message": {
      "type": "string",
      "minLength": 1
    },
    "question_for_next": {
      "type": "string"
    },
    "reply_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 6
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 8
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 10
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 20
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 10
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "needs_human": {
      "type": "boolean"
    }
  }
}
